{
  "productName": "Gepis Dados Abertos",
  "version": "0.1.0",
  "identifier": "com.gepis.dadosabertos",
  "build": {
    "frontendDist": "www/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm run start:dev",
    "beforeBuildCommand": "npm run build",
    "watch": {
      "ignore": [
        "downloads/**",
        "angular-ui/public/data/**"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Gepis Dados Abertos",
        "width": 1200,
        "height": 800
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^https?://.*"
    }
  }
}
