{
  "productName": "Gepis Dados Abertos",
  "version": "0.1.0",
  "identifier": "com.gepis.dadosabertos",
  "build": {
    "frontendDist": "www/browser"
  },
  "app": {
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    },
    "windows": [
      {
        "title": "Gepis Dados Abertos",
        "width": 1200,
        "height": 800
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^https?://.*"
    }
  }
}
