{
  "identifier": "default",
  "description": "Default permissions for the application",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:webview:allow-open-devtools",
    "shell:default",
    "fs:allow-app-read-recursive",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": ["$APPCONFIG/**/*", "$APPDATA/**/*", "$HOME/**/*"]
    },
    "dialog:default",
    "http:default",
    "mcp-gui:default"
  ]
}
